@model WebApplication.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h2>Delete Contract</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this contract? This cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
