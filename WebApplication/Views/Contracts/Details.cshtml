@model WebApplication.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<h2>Contract Details</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Client?.Name</dd>

    <dt class="col-sm-3">Start Date</dt>
    <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">End Date</dt>
    <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @{
            var badgeClass = Model.Status switch
            {
                        "Active" => "bg-success",
                        "Expired" => "bg-danger",
                        "On Hold" => "bg-warning text-dark",
                _ => "bg-secondary"
            };
        }
        <span class="badge @badgeClass">@Model.Status</span>
    </dd>

    <dt class="col-sm-3">Service Level</dt>
    <dd class="col-sm-9">@Model.ServiceLevel</dd>

    <dt class="col-sm-3">Signed Agreement</dt>
    <dd class="col-sm-9">
        @if (!string.IsNullOrEmpty(Model.AgreementFilePath))
        {
            var fn = Model.AgreementFilePath.Split('/').Last();
            <a asp-action="Download" asp-route-fileName="@fn" class="btn btn-sm btn-outline-primary">
                Download PDF
            </a>
        }
        else
        {
            <span class="text-muted">No file uploaded</span>
        }
    </dd>
</dl>

<h4 class="mt-4">Service Requests</h4>

@if (Model.ServiceRequests != null && Model.ServiceRequests.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-secondary">
            <tr>
                <th>Description</th>
                <th>Cost (ZAR)</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sr in Model.ServiceRequests)
            {
                <tr>
                    <td>@sr.Description</td>
                    <td>R @sr.Cost.ToString("N2")</td>
                    <td>@sr.Status</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No service requests linked to this contract yet.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
</div>
