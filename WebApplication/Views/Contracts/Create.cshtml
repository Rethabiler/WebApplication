@model WebApplication.Models.Contract

@{
    ViewData["Title"] = "New Contract";
}

<h2>New Contract</h2>
<hr />

@* enctype="multipart/form-data" is REQUIRED for file uploads — without it the file never reaches the server *@
<form asp-action="Create" method="post" enctype="multipart/form-data">

    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <div class="mb-3">
        <label asp-for="ClientId" class="form-label">Client</label>
        <select asp-for="ClientId" class="form-select" required>
            <option value="">-- Select Client --</option>
            @foreach (var c in (IEnumerable<WebApplication.Models.Client>)ViewBag.Clients)
            {
                <option value="@c.Id">@c.Name (@c.Region)</option>
            }
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="StartDate" class="form-label">Start Date</label>
            <input asp-for="StartDate" type="date" class="form-control" required />
            <span asp-validation-for="StartDate" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="EndDate" class="form-label">End Date</label>
            <input asp-for="EndDate" type="date" class="form-control" required />
            <span asp-validation-for="EndDate" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Status" class="form-label">Status</label>
            <select asp-for="Status" class="form-select" required>
                <option value="">-- Select Status --</option>
                @foreach (var s in (string[])ViewBag.Statuses)
                {
                    <option value="@s">@s</option>
                }
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="ServiceLevel" class="form-label">Service Level</label>
            <select asp-for="ServiceLevel" class="form-select" required>
                <option value="">-- Select Level --</option>
                @foreach (var l in (string[])ViewBag.ServiceLevels)
                {
                    <option value="@l">@l</option>
                }
            </select>
            <span asp-validation-for="ServiceLevel" class="text-danger"></span>
        </div>
    </div>

    @* File upload — name="file" must match the IFormFile parameter name in the controller *@
    <div class="mb-3">
        <label class="form-label">Signed Agreement <span class="text-muted">(PDF only)</span></label>
        <input type="file" name="file" class="form-control" accept=".pdf" />
        <small class="text-muted">Upload the signed contract PDF. Only .pdf files are accepted.</small>
    </div>

    <button type="submit" class="btn btn-primary">Create Contract</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
