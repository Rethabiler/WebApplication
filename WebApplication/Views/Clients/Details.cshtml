@model WebApplication.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<h2>@Model.Name</h2>
<hr />

@* Display the client's info in a clean definition list *@
<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Contact</dt>
    <dd class="col-sm-9">@Model.Contact</dd>

    <dt class="col-sm-3">Region</dt>
    <dd class="col-sm-9">@Model.Region</dd>

    <dt class="col-sm-3">Details</dt>
    <dd class="col-sm-9">@Model.Details</dd>
</dl>

@* 
    The controller used .Include(c => c.Contracts) so we can safely
    access the related contracts here without hitting the DB again.
*@
<h4 class="mt-4">Contracts</h4>

@if (Model.Contracts != null && Model.Contracts.Any())
{
    <table class="table table-sm table-bordered">
        <thead class="table-secondary">
            <tr>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Service Level</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contract in Model.Contracts)
            {
                <tr>
                    <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                    <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                    <td>@contract.Status</td>
                    <td>@contract.ServiceLevel</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">No contracts linked to this client yet.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
</div>
