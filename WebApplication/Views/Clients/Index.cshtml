@* 
    @model tells this view what type of data it received from the controller.
    IEnumerable<Client> = a list of clients.
*@
@model IEnumerable<WebApplication.Models.Client>

@{
    ViewData["Title"] = "Clients"; // sets the browser tab title
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Clients</h2>
    @* asp-action generates the correct /Clients/Create URL automatically *@
    <a asp-action="Create" class="btn btn-primary">+ New Client</a>
</div>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Contact</th>
            <th>Region</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @* Loop through every client the controller passed in *@
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.Name</td>
                <td>@client.Contact</td>
                <td>@client.Region</td>
                <td>
                    @* asp-route-id injects the ID into the URL: /Clients/Details/5 *@
                    <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@* Show a friendly message when the table is empty *@
@if (!Model.Any())
{
    <p class="text-center text-muted mt-4">No clients yet. Click "+ New Client" to add one.</p>
}
