@model IEnumerable<WebApplication.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Service Requests</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Request</a>
</div>

<table class="table table-hover table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Contract</th>
            <th>Client</th>
            <th>Description</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var sr in Model)
        {
            <tr>
                <td>Contract #@sr.ContractId</td>
                <td>@sr.Contract?.Client?.Name</td>
                <td>@sr.Description</td>
                <td>R @sr.Cost.ToString("N2")</td>
                <td>
                    @{
                        var badgeClass = sr.Status switch
                        {
                                        "Completed" => "bg-success",
                                        "Cancelled" => "bg-danger",
                                        "In Progress" => "bg-primary",
                            _ => "bg-warning text-dark"
                        };
                    }
                    <span class="badge @badgeClass">@sr.Status</span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@sr.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@sr.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@sr.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <p class="text-center text-muted mt-4">No service requests yet.</p>
}
