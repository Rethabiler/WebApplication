@model WebApplication.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h2>Delete Service Request</h2>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete this service request? This cannot be undone.
</div>

<dl class="row">
    <dt class="col-sm-3">Contract</dt>
    <dd class="col-sm-9">Contract #@Model.ContractId</dd>

    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Cost</dt>
    <dd class="col-sm-9">R @Model.Cost.ToString("N2")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
