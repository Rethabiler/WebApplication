@model WebApplication.Models.ServiceRequest

@{
    ViewData["Title"] = "New Service Request";
}

<h2>New Service Request</h2>
<hr />

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

    <div class="mb-3">
        <label asp-for="ContractId" class="form-label">Contract</label>
        <select asp-for="ContractId" class="form-select" required>
            <option value="">-- Select Contract --</option>
            @foreach (var c in (IEnumerable<WebApplication.Models.Contract>)ViewBag.Contracts)
            {
                <option value="@c.Id">
                    #@c.Id — @c.Client?.Name (@c.Status, @c.ServiceLevel)
                </option>
            }
        </select>
        @* Note: only Active and Draft contracts appear here — Expired and On Hold are blocked *@
        <small class="text-muted">Only Active and Draft contracts are shown.</small>
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the service required"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Cost" class="form-label">Cost (ZAR)</label>
        <div class="input-group">
            <span class="input-group-text">R</span>
            <input asp-for="Cost" class="form-control" type="number" min="0" step="0.01" placeholder="0.00" />
        </div>
        <span asp-validation-for="Cost" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Status" class="form-label">Status</label>
        <select asp-for="Status" class="form-select" required>
            <option value="">-- Select Status --</option>
            @foreach (var s in (string[])ViewBag.Statuses)
            {
                <option value="@s">@s</option>
            }
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create Request</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
