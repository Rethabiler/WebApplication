@model WebApplication.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<h2>Service Request #@Model.Id</h2>
<hr />

<dl class="row">
    <dt class="col-sm-3">Contract</dt>
    <dd class="col-sm-9">Contract #@Model.ContractId</dd>

    <dt class="col-sm-3">Client</dt>
    <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>

    <dt class="col-sm-3">Cost</dt>
    <dd class="col-sm-9">R @Model.Cost.ToString("N2")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">
        @{
            var badgeClass = Model.Status switch
            {
                        "Completed" => "bg-success",
                        "Cancelled" => "bg-danger",
                        "In Progress" => "bg-primary",
                _ => "bg-warning text-dark"
            };
        }
        <span class="badge @badgeClass">@Model.Status</span>
    </dd>
</dl>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
</div>
